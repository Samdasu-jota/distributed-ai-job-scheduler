# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=scheduler_dev

# ── API Keys (optional — leave blank to use mock backends) ───────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# ── Pipeline Backends ────────────────────────────────────────────────────────
PIPELINE_STT_BACKEND=mock   # mock | whisper | deepgram
PIPELINE_LLM_BACKEND=mock   # mock | claude | openai

# ── Scheduler Tuning ─────────────────────────────────────────────────────────
SCHEDULER_POLL_INTERVAL=2           # seconds between DAG resolution cycles
HEARTBEAT_TIMEOUT_SECONDS=30        # seconds before a worker is declared DEAD
WORKER_HEARTBEAT_INTERVAL=10        # seconds between worker heartbeats
DEAD_MESSAGE_CLAIM_AFTER=60         # seconds before XCLAIM a pending Redis message
